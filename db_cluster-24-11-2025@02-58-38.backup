20251023124415	{"-- Add ig_account_id to integrations and shop_details if missing\nalter table public.integrations\n  add column if not exists ig_account_id text;\n\ncreate index if not exists integrations_ig_account_id_idx\n  on public.integrations(ig_account_id);\n\nalter table public.shop_details\n  add column if not exists ig_account_id text;\n\ncreate index if not exists shop_details_ig_account_id_idx\n  on public.shop_details(ig_account_id);"}	add_ig_account_id_columns	darien.cepani42@gmail.com	\N
20251023140432	{"-- Add display_order to option_values\nalter table if exists option_values\n  add column if not exists display_order integer not null default 0;\n\n-- Initialize display_order for existing values per option by created_at if available\nwith ordered as (\n  select id, option_id,\n         row_number() over (partition by option_id order by coalesce(created_at, now())) - 1 as rn\n  from option_values\n)\nupdate option_values ov\nset display_order = o.rn\nfrom ordered o\nwhere ov.id = o.id;\n\n-- Create product_variants table\ncreate table if not exists product_variants (\n  id uuid primary key default gen_random_uuid(),\n  product_id uuid not null references products(id) on delete cascade,\n  option_value_ids uuid[] not null,\n  inventory integer not null default 0,\n  price_difference numeric not null default 0,\n  is_active boolean not null default true,\n  is_default boolean not null default false,\n  sku text,\n  created_at timestamptz not null default now()\n);\n\n-- Indexes for fast lookup\ncreate index if not exists idx_product_variants_product_id on product_variants(product_id);\ncreate index if not exists idx_product_variants_option_value_ids on product_variants using gin(option_value_ids);\n\n-- Ensure only one default variant per product (partial unique index)\ncreate unique index if not exists uniq_product_variants_default_per_product\n  on product_variants(product_id)\n  where is_default;\n"}	add_product_variants_and_option_value_order	darien.cepani42@gmail.com	\N
20251023154241	{"alter table if exists public.product_variants\n  add column if not exists combination_key text;\n\ncreate index if not exists product_variants_product_combination_idx\n  on public.product_variants(product_id, combination_key);\n"}	add_combination_key_column_only	darien.cepani42@gmail.com	\N
20251023155619	{"-- Enable RLS on involved tables\nalter table if exists public.product_options enable row level security;\nalter table if exists public.option_values enable row level security;\nalter table if exists public.product_variants enable row level security;\n\n-- PRODUCT_OPTIONS policies\ndrop policy if exists owner_select_product_options on public.product_options;\ndrop policy if exists owner_modify_product_options on public.product_options;\ncreate policy owner_select_product_options on public.product_options\n  for select using (\n    exists (\n      select 1 from public.products p\n      where p.id = product_options.product_id and p.user_id = auth.uid()\n    )\n  );\ncreate policy owner_modify_product_options on public.product_options\n  for all using (\n    exists (\n      select 1 from public.products p\n      where p.id = product_options.product_id and p.user_id = auth.uid()\n    )\n  ) with check (\n    exists (\n      select 1 from public.products p\n      where p.id = product_options.product_id and p.user_id = auth.uid()\n    )\n  );\n\n-- OPTION_VALUES policies (via option_id -> product_options -> products)\ndrop policy if exists owner_select_option_values on public.option_values;\ndrop policy if exists owner_modify_option_values on public.option_values;\ncreate policy owner_select_option_values on public.option_values\n  for select using (\n    exists (\n      select 1 from public.product_options po\n      join public.products p on p.id = po.product_id\n      where po.id = option_values.option_id and p.user_id = auth.uid()\n    )\n  );\ncreate policy owner_modify_option_values on public.option_values\n  for all using (\n    exists (\n      select 1 from public.product_options po\n      join public.products p on p.id = po.product_id\n      where po.id = option_values.option_id and p.user_id = auth.uid()\n    )\n  ) with check (\n    exists (\n      select 1 from public.product_options po\n      join public.products p on p.id = po.product_id\n      where po.id = option_values.option_id and p.user_id = auth.uid()\n    )\n  );\n\n-- PRODUCT_VARIANTS policies (via product_id -> products)\ndrop policy if exists owner_select_product_variants on public.product_variants;\ndrop policy if exists owner_modify_product_variants on public.product_variants;\ncreate policy owner_select_product_variants on public.product_variants\n  for select using (\n    exists (\n      select 1 from public.products p\n      where p.id = product_variants.product_id and p.user_id = auth.uid()\n    )\n  );\ncreate policy owner_modify_product_variants on public.product_variants\n  for all using (\n    exists (\n      select 1 from public.products p\n      where p.id = product_variants.product_id and p.user_id = auth.uid()\n    )\n  ) with check (\n    exists (\n      select 1 from public.products p\n      where p.id = product_variants.product_id and p.user_id = auth.uid()\n    )\n  );"}	add_rls_policies_owner_products_options_values_variants	darien.cepani42@gmail.com	\N
20251023165835	{"-- Function to set user_id on product_options from products.user_id\ncreate or replace function public.set_user_id_on_product_options()\nreturns trigger as $$\nbegin\n  if new.user_id is null then\n    select p.user_id into new.user_id from public.products p where p.id = new.product_id;\n  end if;\n  return new;\nend;\n$$ language plpgsql security definer;\n\n-- Trigger\ncreate trigger trg_set_user_id_product_options\nbefore insert or update on public.product_options\nfor each row execute function public.set_user_id_on_product_options();\n\n-- Function to set user_id on option_values from product_options -> products\ncreate or replace function public.set_user_id_on_option_values()\nreturns trigger as $$\nbegin\n  if new.user_id is null then\n    select p.user_id into new.user_id\n    from public.product_options po\n    join public.products p on p.id = po.product_id\n    where po.id = new.option_id;\n  end if;\n  return new;\nend;\n$$ language plpgsql security definer;\n\ncreate trigger trg_set_user_id_option_values\nbefore insert or update on public.option_values\nfor each row execute function public.set_user_id_on_option_values();\n\n-- Function to set user_id on product_variants from products.user_id\ncreate or replace function public.set_user_id_on_product_variants()\nreturns trigger as $$\nbegin\n  if new.user_id is null then\n    select p.user_id into new.user_id from public.products p where p.id = new.product_id;\n  end if;\n  return new;\nend;\n$$ language plpgsql security definer;\n\ncreate trigger trg_set_user_id_product_variants\nbefore insert or update on public.product_variants\nfor each row execute function public.set_user_id_on_product_variants();"}	set_user_id_triggers_for_options_values_variants	darien.cepani42@gmail.com	\N
20251023170609	{"alter table if exists public.product_options\n  alter column id set default gen_random_uuid();"}	set_default_uuid_on_product_options_id	darien.cepani42@gmail.com	\N
20251023172127	{"create extension if not exists pgcrypto;\n\nalter table if exists public.product_options\n  alter column id set default gen_random_uuid();\n\nalter table if exists public.option_values\n  alter column id set default gen_random_uuid();\n\nalter table if exists public.product_variants\n  alter column id set default gen_random_uuid();"}	uuid_defaults_for_options_values_variants	darien.cepani42@gmail.com	\N
20251023190602	{"alter table if exists public.product_variants\n  add column if not exists option_values jsonb not null default '{}'::jsonb;"}	add_option_values_jsonb_to_product_variants	darien.cepani42@gmail.com	\N
20251023202149	{"alter table if exists public.product_variants\n  add column if not exists user_id uuid;\n\ncreate index if not exists product_variants_user_id_idx on public.product_variants(user_id);"}	add_user_id_to_product_variants	darien.cepani42@gmail.com	\N
20251023230207	{"create extension if not exists pgcrypto;\n\nalter table if exists public.product_variants\n  alter column id set default gen_random_uuid();"}	set_default_uuid_on_product_variants_id	darien.cepani42@gmail.com	\N
20251024092351	{"alter table if exists public.product_variants\n  alter column option_value_ids drop not null,\n  alter column option_value_ids set default '{}'::uuid[];"}	relax_not_null_on_product_variants_option_value_ids	darien.cepani42@gmail.com	\N
20251027162406	{"DO $$\nBEGIN\n  -- products: public read of active products\n  IF NOT EXISTS (\n    SELECT 1 FROM pg_policies\n    WHERE schemaname = 'public' AND tablename = 'products' AND policyname = 'public_read_products_active'\n  ) THEN\n    CREATE POLICY \\"public_read_products_active\\"\n    ON public.products\n    FOR SELECT\n    TO anon\n    USING (status = 'Active');\n  END IF;\n\n  -- product_options: public read when product is Active\n  IF NOT EXISTS (\n    SELECT 1 FROM pg_policies\n    WHERE schemaname = 'public' AND tablename = 'product_options' AND policyname = 'public_read_product_options_active_products'\n  ) THEN\n    CREATE POLICY \\"public_read_product_options_active_products\\"\n    ON public.product_options\n    FOR SELECT\n    TO anon\n    USING (\n      EXISTS (\n        SELECT 1 FROM public.products p\n        WHERE p.id = product_options.product_id\n          AND p.status = 'Active'\n      )\n    );\n  END IF;\n\n  -- option_values: public read when option belongs to Active product AND value is active\n  IF NOT EXISTS (\n    SELECT 1 FROM pg_policies\n    WHERE schemaname = 'public' AND tablename = 'option_values' AND policyname = 'public_read_option_values_active'\n  ) THEN\n    CREATE POLICY \\"public_read_option_values_active\\"\n    ON public.option_values\n    FOR SELECT\n    TO anon\n    USING (\n      EXISTS (\n        SELECT 1\n        FROM public.product_options po\n        JOIN public.products p ON p.id = po.product_id\n        WHERE po.id = option_values.option_id\n          AND p.status = 'Active'\n      )\n      AND COALESCE(option_values.is_active, TRUE)\n    );\n  END IF;\n\n  -- product_variants: public read when product is Active AND variant is active\n  IF NOT EXISTS (\n    SELECT 1 FROM pg_policies\n    WHERE schemaname = 'public' AND tablename = 'product_variants' AND policyname = 'public_read_product_variants_active'\n  ) THEN\n    CREATE POLICY \\"public_read_product_variants_active\\"\n    ON public.product_variants\n    FOR SELECT\n    TO anon\n    USING (\n      EXISTS (\n        SELECT 1 FROM public.products p\n        WHERE p.id = product_variants.product_id\n          AND p.status = 'Active'\n      )\n      AND COALESCE(product_variants.is_active, TRUE)\n    );\n  END IF;\nEND$$;"}	public_read_variants_options_active	darien.cepani42@gmail.com	\N
20251027185013	{"-- Enable RLS on tables if they exist\nDO $$ BEGIN\n  IF EXISTS (SELECT 1 FROM information_schema.tables WHERE table_schema = 'public' AND table_name = 'products') THEN\n    EXECUTE 'ALTER TABLE public.products ENABLE ROW LEVEL SECURITY';\n  END IF;\nEND $$;\n\nDO $$ BEGIN\n  IF EXISTS (SELECT 1 FROM information_schema.tables WHERE table_schema = 'public' AND table_name = 'product_options') THEN\n    EXECUTE 'ALTER TABLE public.product_options ENABLE ROW LEVEL SECURITY';\n  END IF;\nEND $$;\n\nDO $$ BEGIN\n  IF EXISTS (SELECT 1 FROM information_schema.tables WHERE table_schema = 'public' AND table_name = 'option_values') THEN\n    EXECUTE 'ALTER TABLE public.option_values ENABLE ROW LEVEL SECURITY';\n  END IF;\nEND $$;\n\nDO $$ BEGIN\n  IF EXISTS (SELECT 1 FROM information_schema.tables WHERE table_schema = 'public' AND table_name = 'product_variants') THEN\n    EXECUTE 'ALTER TABLE public.product_variants ENABLE ROW LEVEL SECURITY';\n  END IF;\nEND $$;\n\n-- Create public read policies if missing\nDO $$ BEGIN\n  IF NOT EXISTS (\n    SELECT 1 FROM pg_policies WHERE schemaname = 'public' AND tablename = 'products' AND policyname = 'public_read_products_active'\n  ) THEN\n    EXECUTE 'CREATE POLICY public_read_products_active ON public.products FOR SELECT TO anon USING (status = ''Active'')';\n  END IF;\nEND $$;\n\nDO $$ BEGIN\n  IF NOT EXISTS (\n    SELECT 1 FROM pg_policies WHERE schemaname = 'public' AND tablename = 'product_options' AND policyname = 'public_read_product_options_active_products'\n  ) THEN\n    EXECUTE 'CREATE POLICY public_read_product_options_active_products ON public.product_options FOR SELECT TO anon USING (EXISTS (SELECT 1 FROM public.products p WHERE p.id = product_options.product_id AND p.status = ''Active''))';\n  END IF;\nEND $$;\n\nDO $$ BEGIN\n  IF NOT EXISTS (\n    SELECT 1 FROM pg_policies WHERE schemaname = 'public' AND tablename = 'option_values' AND policyname = 'public_read_option_values_active'\n  ) THEN\n    EXECUTE 'CREATE POLICY public_read_option_values_active ON public.option_values FOR SELECT TO anon USING (EXISTS (SELECT 1 FROM public.product_options po JOIN public.products p ON p.id = po.product_id WHERE po.id = option_values.option_id AND p.status = ''Active''))';\n  END IF;\nEND $$;\n\nDO $$ BEGIN\n  IF NOT EXISTS (\n    SELECT 1 FROM pg_policies WHERE schemaname = 'public' AND tablename = 'product_variants' AND policyname = 'public_read_product_variants_active'\n  ) THEN\n    EXECUTE 'CREATE POLICY public_read_product_variants_active ON public.product_variants FOR SELECT TO anon USING (EXISTS (SELECT 1 FROM public.products p WHERE p.id = product_variants.product_id AND p.status = ''Active''))';\n  END IF;\nEND $$;"}	public_variants_read_policies_v2	darien.cepani42@gmail.com	\N
20251028113539	{"-- Authenticated users can manage options/variants for their own products\nDO $$ BEGIN\n  IF NOT EXISTS (\n    SELECT 1 FROM pg_policies WHERE schemaname='public' AND tablename='product_options' AND policyname='auth_manage_product_options'\n  ) THEN\n    CREATE POLICY auth_manage_product_options ON public.product_options\n      FOR ALL TO authenticated\n      USING (\n        EXISTS (\n          SELECT 1 FROM public.products p\n          JOIN public.businesses b ON b.id = p.business_id\n          WHERE p.id = product_options.product_id AND b.user_id = auth.uid()\n        )\n      )\n      WITH CHECK (\n        EXISTS (\n          SELECT 1 FROM public.products p\n          JOIN public.businesses b ON b.id = p.business_id\n          WHERE p.id = product_options.product_id AND b.user_id = auth.uid()\n        )\n      );\n  END IF;\nEND $$;\n\nDO $$ BEGIN\n  IF NOT EXISTS (\n    SELECT 1 FROM pg_policies WHERE schemaname='public' AND tablename='option_values' AND policyname='auth_manage_option_values'\n  ) THEN\n    CREATE POLICY auth_manage_option_values ON public.option_values\n      FOR ALL TO authenticated\n      USING (\n        EXISTS (\n          SELECT 1 FROM public.product_options po\n          JOIN public.products p ON p.id = po.product_id\n          JOIN public.businesses b ON b.id = p.business_id\n          WHERE po.id = option_values.option_id AND b.user_id = auth.uid()\n        )\n      )\n      WITH CHECK (\n        EXISTS (\n          SELECT 1 FROM public.product_options po\n          JOIN public.products p ON p.id = po.product_id\n          JOIN public.businesses b ON b.id = p.business_id\n          WHERE po.id = option_values.option_id AND b.user_id = auth.uid()\n        )\n      );\n  END IF;\nEND $$;\n\nDO $$ BEGIN\n  IF NOT EXISTS (\n    SELECT 1 FROM pg_policies WHERE schemaname='public' AND tablename='product_variants' AND policyname='auth_manage_product_variants'\n  ) THEN\n    CREATE POLICY auth_manage_product_variants ON public.product_variants\n      FOR ALL TO authenticated\n      USING (\n        EXISTS (\n          SELECT 1 FROM public.products p\n          JOIN public.businesses b ON b.id = p.business_id\n          WHERE p.id = product_variants.product_id AND b.user_id = auth.uid()\n        )\n      )\n      WITH CHECK (\n        EXISTS (\n          SELECT 1 FROM public.products p\n          JOIN public.businesses b ON b.id = p.business_id\n          WHERE p.id = product_variants.product_id AND b.user_id = auth.uid()\n        )\n      );\n  END IF;\nEND $$;"}	variants_authenticated_write_policies	darien.cepani42@gmail.com	\N
20251029113532	{"-- Create combo (bundle) tables\ncreate table if not exists public.combo_products (\n  id uuid primary key default gen_random_uuid(),\n  title text not null,\n  instagram_post_id text,\n  description text,\n  discount_type text check (discount_type in ('percent','fixed')),\n  discount_value numeric,\n  user_id uuid not null references auth.users(id) on delete cascade,\n  created_at timestamptz not null default now()\n);\n\ncreate table if not exists public.combo_items (\n  id uuid primary key default gen_random_uuid(),\n  combo_id uuid not null references public.combo_products(id) on delete cascade,\n  product_id uuid not null references public.products(id) on delete cascade,\n  required boolean not null default false,\n  min_qty integer not null default 0,\n  max_qty integer not null default 1,\n  display_order integer not null default 0,\n  default_variant_key text,\n  created_at timestamptz not null default now()\n);\n\ncreate index if not exists idx_combo_products_user on public.combo_products(user_id);\ncreate index if not exists idx_combo_products_post on public.combo_products(instagram_post_id);\ncreate index if not exists idx_combo_items_combo on public.combo_items(combo_id);\ncreate index if not exists idx_combo_items_product on public.combo_items(product_id);\n\n-- Enable RLS\nalter table public.combo_products enable row level security;\nalter table public.combo_items enable row level security;\n\n-- Policies: public read (select), owner write\n-- Drop if exists to avoid duplicates on re-run\ndrop policy if exists combo_products_select_public on public.combo_products;\ndrop policy if exists combo_products_modify_owner on public.combo_products;\ndrop policy if exists combo_items_select_public on public.combo_items;\ndrop policy if exists combo_items_modify_owner on public.combo_items;\n\ncreate policy combo_products_select_public on public.combo_products\nfor select using (true);\n\ncreate policy combo_products_modify_owner on public.combo_products\nfor all to authenticated using (auth.uid() = user_id) with check (auth.uid() = user_id);\n\ncreate policy combo_items_select_public on public.combo_items\nfor select using (true);\n\ncreate policy combo_items_modify_owner on public.combo_items\nfor all to authenticated using (\n  exists (\n    select 1 from public.combo_products cp\n    where cp.id = combo_items.combo_id and cp.user_id = auth.uid()\n  )\n) with check (\n  exists (\n    select 1 from public.combo_products cp\n    where cp.id = combo_items.combo_id and cp.user_id = auth.uid()\n  )\n);\n"}	create_combo_products_and_items_v2	darien.cepani42@gmail.com	\N
20251029123934	{"-- Alter combo_items to support internal item data (no separate products)\nalter table public.combo_items\n  alter column product_id drop not null;\n\ndo $$ begin\n  if not exists (\n    select 1 from information_schema.columns\n    where table_schema='public' and table_name='combo_items' and column_name='item_name'\n  ) then\n    alter table public.combo_items add column item_name text;\n  end if;\n  if not exists (\n    select 1 from information_schema.columns\n    where table_schema='public' and table_name='combo_items' and column_name='item_description'\n  ) then\n    alter table public.combo_items add column item_description text;\n  end if;\n  if not exists (\n    select 1 from information_schema.columns\n    where table_schema='public' and table_name='combo_items' and column_name='default_combination_key'\n  ) then\n    alter table public.combo_items add column default_combination_key text;\n  end if;\n  if not exists (\n    select 1 from information_schema.columns\n    where table_schema='public' and table_name='combo_items' and column_name='media'\n  ) then\n    alter table public.combo_items add column media jsonb;\n  end if;\nend $$;\n\n-- Ensure item_name is not null (set fallback then enforce)\nupdate public.combo_items set item_name = coalesce(item_name, 'Item');\nalter table public.combo_items alter column item_name set not null;\n\n-- Create combo_item_options\ncreate table if not exists public.combo_item_options (\n  id uuid primary key default gen_random_uuid(),\n  combo_item_id uuid not null references public.combo_items(id) on delete cascade,\n  name text not null,\n  position smallint,\n  display_order integer not null default 0,\n  created_at timestamptz not null default now()\n);\n\n-- Create combo_option_values\ncreate table if not exists public.combo_option_values (\n  id uuid primary key default gen_random_uuid(),\n  item_option_id uuid not null references public.combo_item_options(id) on delete cascade,\n  value text not null,\n  price_difference numeric,\n  inventory integer,\n  is_active boolean not null default true,\n  is_default boolean not null default false,\n  display_order integer not null default 0,\n  created_at timestamptz not null default now()\n);\n\n-- Create combo_item_variants\ncreate table if not exists public.combo_item_variants (\n  id uuid primary key default gen_random_uuid(),\n  combo_item_id uuid not null references public.combo_items(id) on delete cascade,\n  combination_key text not null,\n  inventory integer,\n  price_difference numeric,\n  is_active boolean not null default true,\n  is_default boolean not null default false,\n  sku text,\n  option_values jsonb,\n  created_at timestamptz not null default now()\n);\n\n-- Indexes\ncreate index if not exists idx_combo_item_options_item on public.combo_item_options(combo_item_id);\ncreate index if not exists idx_combo_option_values_option on public.combo_option_values(item_option_id);\ncreate index if not exists idx_combo_item_variants_item on public.combo_item_variants(combo_item_id);\n\n-- Enable RLS\nalter table public.combo_item_options enable row level security;\nalter table public.combo_option_values enable row level security;\nalter table public.combo_item_variants enable row level security;\n\n-- Policies: public read, owner write (owner via parent combo_products.user_id)\n-- Drop existing to avoid duplicates on re-run\nDO $$ BEGIN\n  IF exists (select 1 from pg_policies where schemaname='public' and tablename='combo_item_options' and policyname='combo_item_options_select_public') THEN\n    drop policy combo_item_options_select_public on public.combo_item_options; END IF;\n  IF exists (select 1 from pg_policies where schemaname='public' and tablename='combo_item_options' and policyname='combo_item_options_modify_owner') THEN\n    drop policy combo_item_options_modify_owner on public.combo_item_options; END IF;\n  IF exists (select 1 from pg_policies where schemaname='public' and tablename='combo_option_values' and policyname='combo_option_values_select_public') THEN\n    drop policy combo_option_values_select_public on public.combo_option_values; END IF;\n  IF exists (select 1 from pg_policies where schemaname='public' and tablename='combo_option_values' and policyname='combo_option_values_modify_owner') THEN\n    drop policy combo_option_values_modify_owner on public.combo_option_values; END IF;\n  IF exists (select 1 from pg_policies where schemaname='public' and tablename='combo_item_variants' and policyname='combo_item_variants_select_public') THEN\n    drop policy combo_item_variants_select_public on public.combo_item_variants; END IF;\n  IF exists (select 1 from pg_policies where schemaname='public' and tablename='combo_item_variants' and policyname='combo_item_variants_modify_owner') THEN\n    drop policy combo_item_variants_modify_owner on public.combo_item_variants; END IF;\nEND $$;\n\ncreate policy combo_item_options_select_public on public.combo_item_options\nfor select using (true);\n\ncreate policy combo_item_options_modify_owner on public.combo_item_options\nfor all to authenticated using (\n  exists (\n    select 1\n    from public.combo_items ci\n    join public.combo_products cp on cp.id = ci.combo_id\n    where ci.id = combo_item_options.combo_item_id and cp.user_id = auth.uid()\n  )\n) with check (\n  exists (\n    select 1\n    from public.combo_items ci\n    join public.combo_products cp on cp.id = ci.combo_id\n    where ci.id = combo_item_options.combo_item_id and cp.user_id = auth.uid()\n  )\n);\n\ncreate policy combo_option_values_select_public on public.combo_option_values\nfor select using (true);\n\ncreate policy combo_option_values_modify_owner on public.combo_option_values\nfor all to authenticated using (\n  exists (\n    select 1\n    from public.combo_item_options cio\n    join public.combo_items ci on ci.id = cio.combo_item_id\n    join public.combo_products cp on cp.id = ci.combo_id\n    where cio.id = combo_option_values.item_option_id and cp.user_id = auth.uid()\n  )\n) with check (\n  exists (\n    select 1\n    from public.combo_item_options cio\n    join public.combo_items ci on ci.id = cio.combo_item_id\n    join public.combo_products cp on cp.id = ci.combo_id\n    where cio.id = combo_option_values.item_option_id and cp.user_id = auth.uid()\n  )\n);\n\ncreate policy combo_item_variants_select_public on public.combo_item_variants\nfor select using (true);\n\ncreate policy combo_item_variants_modify_owner on public.combo_item_variants\nfor all to authenticated using (\n  exists (\n    select 1\n    from public.combo_items ci\n    join public.combo_products cp on cp.id = ci.combo_id\n    where ci.id = combo_item_variants.combo_item_id and cp.user_id = auth.uid()\n  )\n) with check (\n  exists (\n    select 1\n    from public.combo_items ci\n    join public.combo_products cp on cp.id = ci.combo_id\n    where ci.id = combo_item_variants.combo_item_id and cp.user_id = auth.uid()\n  )\n);\n"}	combo_items_internal_options_variants	darien.cepani42@gmail.com	\N
