--
-- Name: order_disputes Admins can manage all disputes; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Admins can manage all disputes" ON public.order_disputes TO authenticated USING ((EXISTS ( SELECT 1
   FROM (public.businesses b
     JOIN public.orders o ON ((b.id = o.business_id)))
  WHERE ((o.id = order_disputes.order_id) AND (b.user_id = auth.uid())))));


--
-- Name: products Allow public read access to active products; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow public read access to active products" ON public.products FOR SELECT TO authenticated, anon USING (((status = 'Active'::text) AND (EXISTS ( SELECT 1
   FROM public.businesses b
  WHERE (b.id = products.business_id)))));


--
-- Name: businesses Allow public read access to business info; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow public read access to business info" ON public.businesses FOR SELECT TO authenticated, anon USING (true);


--
-- Name: design_settings Allow public read access to design settings; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow public read access to design settings" ON public.design_settings FOR SELECT TO authenticated, anon USING (true);


--
-- Name: shop_details Allow public read access to shop details; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow public read access to shop details" ON public.shop_details FOR SELECT TO authenticated, anon USING ((EXISTS ( SELECT 1
   FROM public.businesses b
  WHERE (b.id = shop_details.business_id))));


--
-- Name: ai_analysis_cache Allow user read access to their own cache; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow user read access to their own cache" ON public.ai_analysis_cache FOR SELECT USING ((auth.uid() = user_id));


