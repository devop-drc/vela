--
-- Name: set_user_id_on_option_values(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.set_user_id_on_option_values() RETURNS trigger
    LANGUAGE plpgsql SECURITY DEFINER
    AS $$
begin
  if new.user_id is null then
    select p.user_id into new.user_id
    from public.product_options po
    join public.products p on p.id = po.product_id
    where po.id = new.option_id;
  end if;
  return new;
end;
$$;


ALTER FUNCTION public.set_user_id_on_option_values() OWNER TO postgres;

