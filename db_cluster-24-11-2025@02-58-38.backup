    LANGUAGE plpgsql SECURITY DEFINER
    AS $$
begin
  if new.user_id is null then
    select p.user_id into new.user_id from public.products p where p.id = new.product_id;
  end if;
  return new;
end;
$$;


ALTER FUNCTION public.set_user_id_on_product_options() OWNER TO postgres;

