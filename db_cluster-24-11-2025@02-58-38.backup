   FROM (public.products p
     JOIN public.businesses b ON ((b.id = p.business_id)))
  WHERE ((p.id = product_variants.product_id) AND (b.user_id = auth.uid()))))) WITH CHECK ((EXISTS ( SELECT 1
   FROM (public.products p
     JOIN public.businesses b ON ((b.id = p.business_id)))
  WHERE ((p.id = product_variants.product_id) AND (b.user_id = auth.uid())))));


